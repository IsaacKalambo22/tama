,{\"id\":\"afec178f-06cb-4ca4-8543-d9360d21c9d0\",\"demarcation\":\"esfef\",\"tobaccoType\":\"ewfwef\",\"councillor\":\"ewfwe\",\"firstAlternateCouncillor\":\"wefew\",\"secondAlternateCouncillor\":\"ewfwef\",\"createdAt\":\"2024-11-24T16:23:02.397Z\",\"updatedAt\":\"2024-11-24T16:23:02.397Z\"},{\"id\":\"f8506594-2a7c-4241-b0f9-3bd3889fccc7\",\"demarcation\":\"asfdsaf\",\"tobaccoType\":\"fsaf\",\"councillor\":\"fsadf\",\"firstAlternateCouncillor\":\"fsdf\",\"secondAlternateCouncillor\":\"fdsf\",\"createdAt\":\"2024-11-24T16:30:16.166Z\",\"updatedAt\":\"2024-11-24T16:30:16.166Z\"},{\"id\":\"d172e6d5-e792-4aa2-8c97-d4dd81d91a5d\",\"demarcation\":\"kslafjfa\",\"tobaccoType\":\"fdffd\",\"councillor\":\"sffsf\",\"firstAlternateCouncillor\":\"fsfsf\",\"secondAlternateCouncillor\":\"fdfd\",\"createdAt\":\"2024-11-27T13:40:36.798Z\",\"updatedAt\":\"2024-11-27T13:40:36.798Z\"}]]\n"])</script><script>self.__next_f.push([1,"30:W[\"log\",[[\"fetchNews\",\"/home/programmer/Desktop/programmer/programmerscode/nextjs/tama-farmers-trust/frontend/.next/server/chunks/ssr/[root of the server]__9e46dc._.js\",467,21],[\"async Dashboard\",\"/home/programmer/Desktop/programmer/programmerscode/nextjs/tama-farmers-trust/frontend/.next/server/chunks/ssr/[root of the server]__9e46dc._.js\",678,18]],\"$14\",\"Server\",\"News fetched successfully:\",[{\"id\":\"de75757c-2e73-448c-8d2a-5cd42b342595\",\"title\":\"New Sustainable Agricultural Initiatives Launched\",\"content\":\"TAMA has introduced new initiatives aimed at providing extensive support for farmers. These initiatives focus on enhancing access to resources, training, and financial aid for rural communities. Our goal is to empower farmers with tools and knowledge to improve their yields and secure their livelihoods. Programs include workshops on sustainable agriculture practices, access to microloans, and collaborations with agricultural experts to address challenges in the field. This is a monumental step forward in TAMA’s commitment to fostering agricultural prosperity.\",\"imageUrl\":\"marek-piwnicki-cRCyuPRuVfw-unsplash.jpg\",\"author\":\"John Doe\",\"readingTime\":1,\"createdAt\":\"2024-11-25T12:42:46.242Z\",\"updatedAt\":\"2024-11-25T12:42:46.242Z\"},{\"id\":\"44b1301f-76e2-4811-9778-3df9c6d1cb3a\",\"title\":\"Market Trends Report\",\"content\":\"Our latest report on market trends for farmers is now available. This comprehensive report covers price changes, consumer demand, and emerging markets. Key insights include the growing demand for organic produce, the impact of global supply chains on local markets, and predictions for next season’s most profitable crops. The report also provides data-driven recommendations to help farmers make informed decisions about their crop choices and sales strategies.\",\"imageUrl\":\"pexels-jess-bailey-designs-788948.jpg\",\"author\":\"David Johnson\",\"readingTime\":1,\"createdAt\":\"2024-11-25T14:13:38.560Z\",\"updatedAt\":\"2024-11-25T14:13:38.560Z\"},{\"id\":\"92840299-3a74-4047-b365-944bb8b385ed\",\"title\":\"Sustainable Agriculture Efforts\",\"content\":\"Learn about our sustainable agriculture initiatives aimed at reducing environmental impact while maintaining high productivity. TAMA is committed to promoting practices that conserve water, enhance soil fertility, and reduce chemical use. Recent projects include partnerships with eco-friendly technology providers and the implementation of renewable energy sources on farms. These efforts aim to create a more sustainable and resilient agricultural sector for future generations.\",\"imageUrl\":\"pexels-bruno-cervera-4563937.jpg\",\"author\":\"Sophia Lee\",\"readingTime\":1,\"createdAt\":\"2024-11-25T14:15:13.923Z\",\"updatedAt\":\"2024-11-25T14:15:13.923Z\"},{\"id\":\"81edb71c-e35b-4ed2-a7e5-abd278eec227\",\"title\":\"Farming Techniques Webinar\",\"content\":\"Register for our free webinar on innovative farming techniques that are transforming agriculture today. Topics include precision agriculture, regenerative soil management, and eco-friendly pest control. The webinar will feature experts who will share their insights on optimizing crop yield, conserving water, and reducing costs. This online event is designed to provide practical knowledge that farmers can immediately apply to improve their productivity and sustainability efforts.\",\"imageUrl\":\"pexels-fabian-reitmeier-707915.jpg\",\"author\":\"Jane Doe\",\"readingTime\":1,\"createdAt\":\"2024-11-25T14:16:23.576Z\",\"updatedAt\":\"2024-11-25T14:16:23.576Z\"},{\"id\":\"3b545682-f802-4a63-b824-5a1f204119a6\",\"title\":\"Annual Farmers Conference\",\"content\":\"Join us for the upcoming annual conference to discuss advancements in farming techniques, technology, and industry trends. The conference will feature guest speakers from leading agricultural research institutions, as well as interactive sessions on topics such as crop management, soil health, and climate-resilient farming. Networking opportunities will allow farmers to connect with industry professionals, share experiences, and learn from one another. Don’t miss this opportunity to stay informed and connected in the ever-evolving field of agriculture.\",\"imageUrl\":\"pexels-darsheel-prajapati-4174077.jpg\",\"author\":\"Resten Madzalo\",\"readingTime\":1,\"createdAt\":\"2024-11-25T12:47:17.904Z\",\"updatedAt\":\"2024-11-28T21:25:47.789Z\"}]]\n"])</script><script>self.__next_f.push([1,"33:{\"name\":\"Card\",\"env\":\"Server\",\"key\":\"0\",\"owner\":\"$14\",\"props\":{\"className\":\"shadow-none rounded-xl overflow-hidden hover:shadow-xl transition-shadow duration-300 p-6 flex items-center justify-between\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-center space-x-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"p-4 bg-blue-50 rounded-lg\",\"children\":[\"$\",\"$E(function FaStore(props) {\\n    return (0, __TURBOPACK__imported__module__$5b$project$5d2f$node_modules$2f2e$pnpm$2f$react$2d$icons$40$5$2e$3$2e$0_react$40$19$2e$0$2e$0$2d