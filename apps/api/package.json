{
  "name": "api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "concurrently \" tsc -w\" \"nodemon --exec 'node -r esbuild-register ./src/index.ts' -e ts\"",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts*\" --max-warnings 0",
    "lint:fix": "tsc --noEmit && eslint \"src/**/*.ts*\" --max-warnings 0 --fix",
    "start": "node -r esbuild-register ./src/index.ts",
    "format:check": "prettier --check ./src",
    "format": "prettier --write ./src ",
    "studio": "pnpm prisma studio",
    "db:migrate": "pnpm prisma migrate dev",
    "generate": "pnpm prisma generate",
    "migrate": "pnpm prisma migrate dev && pnpm prisma generate",
    "db:deploy": "pnpm prisma migrate deploy && pnpm prisma generate"

  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@types/body-parser": "^1.19.5",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@eslint/eslintrc": "^3.3.1",
    "bcryptjs": "^3.0.2",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.16",
    "twilio": "^5.5.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.0",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.7",
    "esbuild": "^0.25.2",
    "esbuild-register": "^3.6.0",
    "eslint": "^9.24.0",
    "nodemon": "^3.1.9",
    "prettier-plugin-organize-imports": "^4.1.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.17",
    "concurrently": "^9.1.2",
    "prisma": "^6.6.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
